---
import Layout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AboutCompanyLayout from '../../layouts/AboutCompanyLayout.astro';
import Link from '../../components/Link.astro';

const breadcrumbItems = [
  { title: 'Главная', href: '/' },
  { title: 'О компании', href: '/aboutcompany/' },
  { title: 'Статьи' },
];
---

<Layout
  title="Полезные статьи о современном складском оборудовании и прочих стелажах - ЗАО «КМ-про»"
  description="Статьи о стеллажном оборудовании от поставщика ЗАО «КМ-про» ⭐⭐⭐⭐⭐ Звоните 📞 +375 (29) 178-70-18"
  ogSiteName="Сайт компании ЗАО «КМ-про»"
  ogUrl="https://stellazhi.by/aboutcompany/about/"
  ogTitle="Полезные статьи о современном складском оборудовании и прочих стелажах - ЗАО «КМ-про»"
  ogDescription="Статьи о стеллажном оборудовании от поставщика ЗАО «КМ-про» ⭐⭐⭐⭐⭐ Звоните 📞 +375 (29) 178-70-18"
  ogImage="https://stellazhi.by/images/KM-Pro.webp"
  ogLocality="ru_BY"
  canonicalUrl="https://stellazhi.by/aboutcompany/articles/"
  customMetas={[
    {
      name: 'keywords',
      content: 'Полезные статьи о современном складском оборудовании и прочих стелажах - ЗАО «КМ-про»',
    },
  ]}
>
  <Breadcrumbs items={breadcrumbItems} />

  <AboutCompanyLayout>
    <div class="prose max-w-none">
      <h1 class="text-2xl font-bold mb-6">Полезные статьи</h1>

      <ul class="space-y-3 list-none pl-0">
        <li>
          <Link href="/aboutcompany/articles/vidi_skladskih_stellazhej_i_ih_osobennos/">
            Виды складских стеллажей и их особенности применения
          </Link>
        </li>
        <li>
          <Link href="/stellazh-arhivnyj-metallicheskij/">
             Стеллаж архивный металлический
          </Link>
        </li>
        <li>
          <Link href="/stellazh-sbornyj-s-polkami-metallicheskij/">
            Стеллаж сборный с полками металлический
          </Link>
        </li>
        <li>
          <Link href="/shattlovye-stellazhi/">
            Шаттловые стеллажи
          </Link>
        </li>
      </ul>
    </div>
  </AboutCompanyLayout>
</Layout>
